# Copy to .env.local and fill in.
# After `supabase start` the CLI prints anon key + service_role for the local stack.

# Supabase — public (safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server only (NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (optional — F2)
RESEND_API_KEY=
RESEND_FROM_EMAIL=GestionFinca <no-reply@gestionfinca.app>
